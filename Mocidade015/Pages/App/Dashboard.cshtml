@page
@model Mocidade015.Pages.App.DashboardModel
@{
    ViewData["Title"] = "Escolha seu Embarque";
}

<div class="card shadow border-0 rounded-4 mb-4">
    <div class="card-body p-4">
        <h4 class="fw-bold text-azul-escuro mb-1">Olá, @User.Identity?.Name!</h4>
        <p class="text-muted small mb-4">Para onde vamos no dia 26/07?</p>

        <div class="list-group gap-3">
            @foreach (var item in Model.ListaOnibus)
            {
                <div class="list-group-item border rounded-3 p-3 shadow-sm">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="fw-bold mb-1 text-azul-escuro">Terminal @item.Onibus.TerminalSaida</h6>
                            <div class="d-flex gap-2 mt-1">
                                <div class="badge bg-light text-dark border">
                                    🕒 Saída: @item.Onibus.HorarioSaida.ToString(@"hh\:mm")
                                </div>
                                <div class="badge @(item.EstaLotado ? "bg-danger" : "bg-success")">
                                    @item.Ocupados/@item.LotacaoMaxima @(item.EstaLotado ? "Lotado" : "Lugares")
                                </div>
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            @if (item.EstaLotado)
                            {
                                <a asp-page="/App/ListaEspera" asp-route-terminal="@item.Onibus.TerminalSaida"
                                   class="btn btn-warning btn-sm px-3 fw-bold">
                                    <i class="bi bi-clock-history me-1"></i>Lista de Espera
                                </a>
                            }
                            else
                            {
                                <a asp-page="/App/Identificacao" asp-route-onibusId="@item.Onibus.Id"
                                   class="btn btn-primary-custom btn-sm px-3 fw-bold">
                                    Selecionar
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (!Model.ListaOnibus.Any())
        {
            <div class="text-center py-4">
                <p class="text-muted">Nenhum ônibus disponível para esta data.</p>
                <code class="small text-danger">Dica: Rode o script SQL de inserção no Supabase.</code>
            </div>
        }
    </div>
</div>