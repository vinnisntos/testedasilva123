@page
@model Mocidade015.Pages.App.AcompanhantesModel
@{
    ViewData["Title"] = "Meus Acompanhantes";
}

<div class="container py-4">
    <div class="row">
        <div class="col-md-5 mb-4">
            <div class="card shadow border-0 rounded-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold text-azul-escuro mb-3">Novo Acompanhante</h5>
                    <form method="post">
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Nome Completo</label>
                            <input asp-for="NovoAcompanhante.Nome" class="form-control" placeholder="Nome do passageiro" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">RG ou CPF</label>
                            <input asp-for="NovoAcompanhante.RgCpf" class="form-control" placeholder="00.000.000-0" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Telefone</label>
                            <input asp-for="NovoAcompanhante.Telefone" class="form-control" placeholder="(15) 99999-9999" />
                        </div>
                        <button type="submit" class="btn btn-primary-custom w-100 fw-bold">Cadastrar</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-7">
            <div class="card shadow border-0 rounded-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold text-azul-escuro mb-3">Pessoas Cadastradas</h5>
                    
                    @if (!Model.ListaAcompanhantes.Any())
                    {
                        <p class="text-muted small">Você ainda não cadastrou nenhum acompanhante.</p>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var item in Model.ListaAcompanhantes)
                            {
                                <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                                    <div>
                                        <h6 class="mb-0 fw-bold">@item.Nome</h6>
                                        <small class="text-muted">Doc: @item.RgCpf | Tel: @(item.Telefone ?? "Não informado")</small>
                                    </div>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id">
                                        <button class="btn btn-link text-danger p-0">
                                            <i class="bi bi-trash"></i> Excluir
                                        </button>
                                    </form>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
            <div class="mt-3">
                <a asp-page="/App/Dashboard" class="text-decoration-none small text-secondary">
                    ← Voltar para o Dashboard
                </a>
            </div>
        </div>
    </div>
</div>