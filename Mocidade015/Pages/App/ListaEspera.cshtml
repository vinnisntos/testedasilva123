@page
@model Mocidade015.Pages.App.ListaEsperaModel
@{
    ViewData["Title"] = "Entrar na Lista de Espera";
}

<div class="container py-5 text-center">
    <div class="card shadow-lg p-4 rounded-4 border-0 mx-auto" style="max-width: 500px;">
        <i class="bi bi-clock-history text-warning" style="font-size: 4rem;"></i>
        <h2 class="fw-bold text-azul-escuro mt-3">Lista de Espera</h2>
        
        <p class="text-muted mt-3">
            Olá, <strong>@Model.NomeUsuario</strong>!<br>
            Você está entrando na lista de espera para o destino:<br>
            <span class="badge bg-primary fs-5 mt-2">📍 @Model.Terminal</span>
        </p>

        <form method="post" class="mt-4">
            <input type="hidden" asp-for="Terminal" />
            
            <button type="submit" class="btn btn-warning w-100 py-3 fw-bold rounded-3 shadow-sm mb-3">
                <i class="bi bi-check-lg"></i> Confirmar meu nome na lista
            </button>
            
            <a href="/App/Dashboard" class="btn btn-outline-secondary w-100">Cancelar e voltar</a>
        </form>
    </div>
</div>
