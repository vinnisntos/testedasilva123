@page
@model Mocidade015.Pages.App.ListaEsperaModel
@{
    ViewData["Title"] = "Lista de Espera";
}

<div class="container py-5 text-center">
    <div class="card shadow-lg p-4 rounded-4 border-0 mx-auto" style="max-width: 500px;">
        <i class="bi bi-clock-history text-warning" style="font-size: 4rem;"></i>
        <h2 class="fw-bold text-azul-escuro mt-3">Lista de Espera</h2>
        <p class="text-muted">
            Você está entrando na lista para o terminal: <strong>@Model.Terminal</strong>
        </p>

        <form method="post">
            <input type="hidden" asp-for="Terminal" />
            <button type="submit" class="btn btn-primary-custom w-100 py-3 fw-bold rounded-3 shadow">
                Confirmar meu nome na lista
            </button>
        </form>
    </div>
</div>
