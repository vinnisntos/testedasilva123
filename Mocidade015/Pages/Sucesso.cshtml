@page
@model Mocidade015.Pages.SucessoModel
@{
    ViewData["Title"] = "Reserva Confirmada";
}

<div class="container mx-auto px-4 py-20 max-w-2xl text-center mt-10">
    
    <div class="mb-8 flex justify-center">
        <div class="rounded-full bg-green-500/10 p-6 ring-8 ring-green-500/5 animate-bounce">
            <svg class="w-16 h-16 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
            </svg>
        </div>
    </div>

    <h2 class="text-4xl font-extrabold text-white font-title mb-4">
        Reserva <span class="text-mocidade-blue">Confirmada!</span>
    </h2>
    
    <p class="text-gray-300 text-lg mb-8">
        Tudo certo, Vinnicius! O pagamento foi identificado e sua vaga na excursão da
        <span class="text-white font-semibold">Mocidade 015</span> está garantida.
    </p>

    <div class="bg-gray-800 border border-gray-700 rounded-2xl p-6 mb-10 text-left shadow-2xl">
        <h3 class="text-white font-bold mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-mocidade-blue" fill="currentColor" viewBox="0 0 20 20"><path d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-11H9v2h2V7zm0 4H9v4h2v-4z" /></svg>
            Próximos Passos:
        </h3>
        <ul class="space-y-4 text-gray-400 text-sm">
            <li class="flex gap-3">
                <span class="bg-gray-700 text-white w-5 h-5 rounded-full flex items-center justify-center text-[10px] shrink-0">1</span>
                <span>Enviamos um comprovante detalhado para o seu e-mail cadastrado.</span>
            </li>
            <li class="flex gap-3">
                <span class="bg-gray-700 text-white w-5 h-5 rounded-full flex items-center justify-center text-[10px] shrink-0">2</span>
                <span>Fique atento ao grupo do WhatsApp da excursão para horários de saída.</span>
            </li>
            <li class="flex gap-3">
                <span class="bg-gray-700 text-white w-5 h-5 rounded-full flex items-center justify-center text-[10px] shrink-0">3</span>
                <span>Não esqueça de levar seu documento original com foto no dia da viagem.</span>
            </li>
        </ul>
    </div>

    <div class="flex flex-col md:flex-row gap-4 justify-center">
        <a href="/" class="px-8 py-3 bg-gray-700 hover:bg-gray-600 text-white font-bold rounded-xl transition-all">
            Voltar para o Início
        </a>
        <button onclick="window.print()" class="px-8 py-3 bg-mocidade-blue hover:bg-blue-500 text-white font-bold rounded-xl transition-all shadow-[0_0_15px_rgba(76,163,237,0.3)]">
            Imprimir Comprovante
        </button>
    </div>

</div>