@page
@model Mocidade015.Pages.Admin.IndexModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Gestão de Embarque";
}

<div class="container-fluid mt-4" style="max-width: 1400px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-azul-escuro m-0">Painel Administrativo</h2>
            <p class="text-muted small">Gerencie passageiros e lista de espera para 26/07</p>
        </div>
        <button onclick="window.print()" class="btn btn-dark d-print-none shadow-sm">
            <i class="bi bi-printer"></i> Imprimir Listas
        </button>
    </div>

    @if (TempData["Mensagem"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm rounded-3">@TempData["Mensagem"]</div>
    }

    <div class="row g-4 mb-5">
        @foreach (var onibus in Model.RelatorioOnibus)
        {
            <div class="col-xl-6">
                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-header bg-azul-escuro text-white d-flex justify-content-between align-items-center py-3">
                        <span class="fw-bold">🚌 Ônibus #@onibus.Numero - @onibus.Terminal</span>
                        <span class="badge @(onibus.TotalOcupados >= onibus.LotacaoMaxima ? "bg-danger" : "bg-success")">
                            @onibus.TotalOcupados / @onibus.LotacaoMaxima Ocupados
                        </span>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive" style="max-height: 400px;">
                            <table class="table table-hover table-sm mb-0">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th class="ps-3">Poltrona</th>
                                        <th>Passageiro</th>
                                        <th>Documento</th>
                                        <th>Telefone</th>
                                        <th>Ações</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var r in onibus.Reservas)
                                    {
                                        <tr>
                                            <td class="ps-3 fw-bold">#@r.Assento.Numero.ToString("D2")</td>
                                            <td>
                                                <span class="d-block fw-semibold">@(r.Acompanhante?.Nome ?? r.Usuario.Nome)</span>
                                                <small class="text-muted">@(r.AcompanhanteId == null ? "Titular" : "Acompanhante")</small>
                                            </td>
                                            <td class="small">@(r.Acompanhante?.RgCpf ?? r.Usuario.Rg)</td>
                                            <td class="small">@(r.Acompanhante?.Telefone ?? r.Usuario?.Telefone ?? "-")</td>
                                            <td>
                                                <form method="post" asp-page-handler="CancelarReserva" asp-route-reservaId="@r.Id" 
                                                      onsubmit="return confirm('Deseja liberar este assento?');" class="d-inline">
                                                    <button class="btn btn-outline-danger btn-sm border-0">
                                                        <i class="bi bi-person-x"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @* SEÇÃO: LISTA DE ESPERA *@
    <div class="mt-5 d-print-none">
        <h4 class="fw-bold text-azul-escuro mb-3">⏳ Lista de Espera</h4>
        <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Solicitante</th>
                            <th>Email</th>
                            <th>Telefone</th>
                            <th>Terminal</th>
                            <th>Data/Hora</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.FilaEspera.Any())
                        {
                            <tr><td colspan="5" class="text-center py-4 text-muted">Ninguém na espera por enquanto.</td></tr>
                        }
                        @foreach (var espera in Model.FilaEspera)
                        {
                            <tr>
                                <td class="ps-4 fw-bold">@espera.Usuario?.Nome</td>
                                <td>@espera.Usuario?.Email</td>
                                <td>@(espera.Usuario?.Telefone ?? "-")</td>
                                <td><span class="badge bg-warning text-dark">@espera.TerminalDesejado</span></td>
                                <td class="small text-muted">@espera.DataSolicitacao.ToString("dd/MM HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .table-responsive::-webkit-scrollbar { width: 5px; }
    .table-responsive::-webkit-scrollbar-thumb { background: #ddd; border-radius: 10px; }
    @@media print { .d-print-none { display: none !important; } .card { break-inside: avoid; } }
</style>