@page
@model Mocidade015.Pages.PagamentoModel
@{
    ViewData["Title"] = "Finalizar Pagamento";
}

<div class="container mx-auto px-4 py-10 max-w-2xl mt-10">
    <div class="text-center mb-8">
        <h2 class="text-3xl md:text-4xl font-extrabold text-white font-title mb-2">Finalizar <span class="text-mocidade-blue">Reserva</span></h2>
        <p class="text-gray-400">Escolha a forma de pagamento para garantSSir suas vagas.</p>
    </div>

    @if (Model.PagamentoBloqueado)
    {
        <div class="flex flex-col items-center justify-center p-8 bg-gray-900 rounded-xl border border-gray-700 shadow-2xl mb-8">
            <h3 class="text-2xl text-yellow-400 font-bold mb-4 text-center">Aviso da Reserva</h3>
            <p class="text-gray-300 mb-6 text-center text-lg">@Model.MensagemBloqueio</p>
            <a href="/" class="px-8 py-3 bg-mocidade-blue hover:bg-blue-600 text-white font-bold rounded-xl transition-all">
                Voltar ao Início
            </a>
        </div>
    }
    else
    {
        <!-- 1. CAIXA DO PIX -->
        <div class="flex flex-col items-center justify-center p-8 bg-gray-900 rounded-xl border border-gray-700 shadow-2xl mb-8">
            <h3 class="text-xl text-white font-bold mb-4">Pagar com PIX (Sem taxa)</h3>
            <p class="text-gray-300 mb-6 text-center text-lg">Total a pagar: <strong class="text-green-400 text-2xl ml-2">R$ @Model.ValorPix.ToString("N2")</strong></p>
            
            @if (!string.IsNullOrEmpty(Model.PixQrCodeBase64))
            {
                <img src="data:image/png;base64,@Model.PixQrCodeBase64" alt="QR Code PIX" class="w-56 h-56 mb-8 border-4 border-white rounded-xl p-2 bg-white shadow-lg">
            }
            else
            {
                <p class="text-red-400 mb-6 font-semibold">Erro ao gerar o QR Code. O Mercado Pago recusou a requisição.</p>
            }

            <div class="w-full flex flex-col gap-3">
                <label class="text-sm text-gray-400 font-medium">Ou pague com o código "Copia e Cola":</label>
                <div class="flex gap-2">
                    <input type="text" id="pixCode" readonly value="@Model.PixCopiaECola" class="w-full bg-gray-800 border border-gray-600 rounded-lg px-4 py-3 text-sm text-gray-400 font-mono focus:outline-none focus:ring-2 focus:ring-mocidade-blue">
                    <button type="button" onclick="copiarPix()" class="px-6 py-3 bg-mocidade-blue hover:bg-blue-600 text-white rounded-lg transition-all font-bold whitespace-nowrap shadow-lg">
                        Copiar
                    </button>
                </div>
            </div>
        </div>

        <!-- 2. CAIXA DO CARTÃO DE CRÉDITO/DÉBITO -->
        <div class="flex flex-col p-8 bg-gray-900 rounded-xl border border-gray-700 shadow-2xl">
            <h3 class="text-xl text-white font-bold mb-2 text-center">Cartão de Crédito ou Débito</h3>
            <p class="text-gray-400 mb-8 text-center text-sm">Com repasse de taxa da operadora. Total: <strong class="text-yellow-400">R$ @Model.ValorCartao.ToString("N2")</strong></p>
            
            <div id="paymentBrick_container"></div>
        </div>
    }
</div>

@Html.AntiForgeryToken()

@section Scripts {
    @if (!Model.PagamentoBloqueado)
    {
        <script>
            function copiarPix() {
                var copyText = document.getElementById("pixCode");
                copyText.select();
                copyText.setSelectionRange(0, 99999);
                navigator.clipboard.writeText(copyText.value);
                alert("Código Pix copiado com sucesso!");
            }
        </script>

        <script src="https://sdk.mercadopago.com/js/v2"></script>
        <script>
            // Sua chave pública exata aqui!
            const mp = new MercadoPago('APP_USR-1e76989b-c0fe-49a2-9cd0-143e462ceafd', {
            locale: 'pt-BR'
            });

            const bricksBuilder = mp.bricks();
            
            const renderPaymentBrick = async (bricksBuilder) => {
            const settings = {
            initialization: {
            amount: @Model.ValorCartao.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture),
            },
            customization: {
            visual: {
            style: {
            theme: "dark",
            }
            },
            paymentMethods: {
            creditCard: "all",
            debitCard: "all"
            },
            },
            callbacks: {
            onReady: () => {
            console.log("Formulário de cartão carregado!");
            },
            onSubmit: ({ selectedPaymentMethod, formData }) => {
            return new Promise((resolve, reject) => {
            fetch("/Pagamento?handler=ProcessarCartao&loteId=@Model.LoteId", {
            method: "POST",
            headers: {
            "Content-Type": "application/json",
            "RequestVerificationToken": document.getElementsByName("__RequestVerificationToken")[0].value
            },
            body: JSON.stringify(formData)
            })
            .then((response) => response.json())
            .then((data) => {
            if (data.success) {
            window.location.href = "/Sucesso";
            } else {
            alert("Pagamento recusado: " + data.status);
            }
            resolve();
            })
            .catch((error) => {
            console.error(error);
            reject();
            });
            });
            },
            onError: (error) => {
            console.error("Erro no Brick:", error);
            },
            },
            };
            window.paymentBrickController = await bricksBuilder.create(
            "payment",
            "paymentBrick_container",
            settings
            );
            };
            
            renderPaymentBrick(bricksBuilder);
        </script>
    }
}