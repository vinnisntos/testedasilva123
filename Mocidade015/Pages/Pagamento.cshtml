@page
@model Mocidade015.Pages.PagamentoModel
@{
    ViewData["Title"] = "Finalizar Pagamento";

    // Regra financeira básica: se não vier quantidade na URL, assumimos 1.
    int qtdPassagens = Model.QuantidadePessoas;
    decimal valorUnitario = 30.00m;
    decimal valorTotal = qtdPassagens * valorUnitario;
}

<div class="container mx-auto px-4 py-10 max-w-5xl mt-10">
    
    <div class="text-center mb-10">
        <h2 class="text-3xl md:text-4xl font-extrabold text-white font-title mb-2">Finalizar <span class="text-mocidade-blue">Reserva</span></h2>
        <p class="text-gray-400">Escolha a forma de pagamento. Seus lugares estão pré-reservados.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <div class="lg:col-span-1 space-y-6">
            <div class="bg-gray-800 p-6 rounded-2xl border border-gray-700 shadow-lg">
                <h3 class="text-lg font-bold text-white mb-4 border-b border-gray-700 pb-2">Resumo da Viagem</h3>
                
                <div class="flex justify-between items-center mb-3 text-gray-300">
                    <span>Passagem Excursão</span>
                    <span>@qtdPassagens x R$ 30,00</span>
                </div>
                
                <div class="flex justify-between items-center mb-6 text-gray-400 text-sm">
                    <span>Taxas</span>
                    <span>R$ 0,00</span>
                </div>

                <div class="flex justify-between items-center pt-4 border-t border-gray-700">
                    <span class="text-xl font-bold text-white">Total</span>
                    <span class="text-2xl font-extrabold text-mocidade-blue">R$ @valorTotal.ToString("N2")</span>
                </div>
            </div>

            <div class="bg-gray-800/50 p-4 rounded-xl border border-gray-700 text-sm text-gray-400 text-center">
                <p>Ambiente seguro e criptografado.</p>
                <p>Seus dados estão protegidos (LGPD).</p>
            </div>
        </div>

        <div class="lg:col-span-2">
            <div class="bg-gray-800 p-6 md:p-8 rounded-2xl border border-gray-700 shadow-lg">
                <h3 class="text-xl font-bold text-white mb-6">Forma de Pagamento</h3>

                <div class="flex gap-4 mb-8">
                    <button class="flex-1 py-3 border-2 border-mocidade-blue bg-mocidade-blue/10 text-mocidade-blue rounded-xl font-semibold flex items-center justify-center gap-2 transition-all">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                        PIX
                    </button>
                    <button class="flex-1 py-3 border border-gray-600 hover:border-gray-500 text-gray-400 rounded-xl font-semibold flex items-center justify-center gap-2 transition-all opacity-50 cursor-not-allowed" title="Em breve">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
                        Cartão
                    </button>
                </div>

                <div class="flex flex-col items-center justify-center py-6">
                    <div class="bg-white p-2 rounded-xl mb-6">
                        <img src="https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=ExcursaoMocidade015" alt="QR Code Pix" class="w-48 h-48">
                    </div>
                    
                    <p class="text-gray-300 text-center mb-4">Escaneie o QR Code ou copie o código Pix abaixo para pagar <strong class="text-white">R$ @valorTotal.ToString("N2")</strong></p>

                    <div class="w-full flex">
                        <input type="text" readonly value="00020126580014br.gov.bcb.pix0136[CODIGO_MERCADO_PAGO_AQUI]" class="w-full bg-gray-900 border border-gray-600 rounded-l-lg px-4 py-3 text-gray-400 font-mono text-sm outline-none">
                        <button class="bg-gray-700 hover:bg-gray-600 px-6 rounded-r-lg text-white font-semibold transition-colors border-y border-r border-gray-600">
                            Copiar
                        </button>
                    </div>
                </div>

                <div class="mt-8 border-t border-gray-700 pt-6">
                    <a href="/Sucesso" class="block w-full text-center px-8 py-4 bg-green-600 hover:bg-green-500 text-white font-bold text-lg rounded-xl shadow-[0_0_15px_rgba(22,163,74,0.3)] transition-all transform hover:scale-105">
                        Simular Pagamento Confirmado
                    </a>
                </div>
            </div>
        </div>

    </div>
</div>