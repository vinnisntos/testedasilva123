@page
@model Mocidade015.Pages.CadastroModel
@{
    ViewData["Title"] = "Criar Conta";
}

<div class="card shadow border-0 rounded-4">
    <div class="card-body p-4">
        <h3 class="text-center text-azul-escuro fw-bold mb-3">Cadastre-se</h3>
        <p class="text-center text-muted small mb-4">Crie sua conta para reservar sua passagem.</p>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="mb-3">
                <label asp-for="Input.Nome" class="form-label fw-bold">Nome Completo</label>
                <input asp-for="Input.Nome" class="form-control" placeholder="Vinnicius Gabriel..." required />
            </div>

            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label fw-bold">E-mail</label>
                <input asp-for="Input.Email" type="email" class="form-control" placeholder="exemplo@email.com" required />
            </div>

            <div class="mb-3">
                <label asp-for="Input.Rg" class="form-check label fw-bold">RG/CPF</label>
                <input asp-for="Input.Rg" type="rg" class="form-control" placeholder="12.345.678-9" required/>
            </div>

            <div class="mb-4">
                <label asp-for="Input.Senha" class="form-label fw-bold">Senha</label>
                <input asp-for="Input.Senha" type="password" class="form-control" placeholder="••••••••" required />
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-primary-custom btn-lg fw-bold">Criar Minha Conta</button>
            </div>
        </form>

        <div class="text-center mt-3">
            <a asp-page="/Login" class="text-decoration-none text-muted small">Já tem conta? Faça login</a>
        </div>
    </div>
</div>