@page
@model Mocidade015.Pages.IndexModel
@{
    ViewData["Title"] = "Página Inicial";
}

<div class="card shadow-lg border-0 rounded-4">
    <div class="card-body p-5 text-center">
        <h1 class="text-azul-escuro fw-bold mb-2">Bem-vindo!</h1>
        <h5 class="text-secondary mb-4">Sistema de Reservas</h5>
        
        <p class="text-muted mb-4" style="font-size: 0.95rem;">
            Garanta sua passagem para a viagem do dia <strong>26/07</strong> de forma rápida e segura.<br /><br />
            Escolha seu terminal, selecione sua poltrona e pronto!
        </p>

        <div class="d-grid gap-3 mt-4">
            <a asp-page="/Login" class="btn btn-primary-custom btn-lg rounded-3 fw-bold">Fazer Login</a>
            <a asp-page="/Cadastro" class="text-decoration-none text-azul-escuro fw-semibold mt-2">Ainda não tem conta? Cadastre-se</a>
        </div>
    </div>
</div>