@page
@model IndexModel
@{
    ViewData["Title"] = "Início";
}

<div class="relative min-h-screen flex flex-col items-center justify-center bg-cover bg-center" style="background-image: url('/images/background-igreja.png');">
    
    <div class="absolute inset-0 bg-mocidade-dark bg-opacity-80"></div>

    <div class="relative z-10 text-center px-4 max-w-3xl mx-auto mt-10">
        
        <h1 class="font-title text-5xl md:text-7xl font-extrabold text-white tracking-tight drop-shadow-lg mb-2">
            Mocidade <span class="text-mocidade-blue">015</span>
        </h1>
        <p class="text-gray-300 text-lg md:text-xl font-medium mb-8">
            Sorocaba & Região
        </p>

        <div class="bg-black bg-opacity-60 p-6 md:p-8 rounded-2xl border border-gray-700 backdrop-blur-sm mb-10 shadow-xl">
            <h2 class="text-2xl font-bold mb-4 text-mocidade-blue">Excursão Oficial</h2>
            <p class="text-gray-200 mb-6 text-left md:text-center leading-relaxed text-lg">
                Junte-se a nós nesta visita especial a nossa filial. Serão apenas <strong class="text-white">64 lugares</strong> disponíveis em um ônibus executivo confortável.
            </p>
            <p class="text-sm text-gray-400">
                Garanta seu lugar e o de seus acompanhantes com segurança e praticidade.
            </p>
        </div>

        <div class="flex flex-col items-center">
            <div class="flex items-center gap-3 mb-6">
                <input type="checkbox" id="termos" name="termos" class="w-5 h-5 rounded border-gray-500 text-mocidade-blue focus:ring-mocidade-blue cursor-pointer">
                <label for="termos" class="text-sm text-gray-300 cursor-pointer select-none">
                    Afirmo que li os termos de viagem e concordo com os mesmos.
                </label>
            </div>

            <a href="/Cadastro" id="btnGarantir" class="px-10 py-4 bg-mocidade-blue hover:bg-blue-500 text-white font-bold text-xl rounded-full transition-all transform hover:scale-105 shadow-[0_0_20px_rgba(76,163,237,0.4)]">
                Garantir Meu Lugar
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('btnGarantir').addEventListener('click', function(e) {
            const checkboxTermos = document.getElementById('termos');
            
            if (!checkboxTermos.checked) {
                e.preventDefault(); // Impede o link de abrir a página de cadastro
                
                // Dá um alerta simples para o usuário
                alert('Ei! Você precisa aceitar os termos de viagem para garantir seu lugar.');
                
                // Opcional: faz a caixinha piscar pra chamar atenção
                checkboxTermos.classList.add('ring-2', 'ring-red-500', 'ring-offset-2', 'ring-offset-mocidade-dark');
                setTimeout(() => {
                    checkboxTermos.classList.remove('ring-2', 'ring-red-500', 'ring-offset-2', 'ring-offset-mocidade-dark');
                }, 2000);
            }
        });
    </script>
}